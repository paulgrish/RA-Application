<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/card_margin_half"
    android:layout_marginVertical="@dimen/card_margin_half"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_card_image"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:scaleType="centerCrop"
            tools:src="@drawable/title_image_preview" />

        <TextView
            android:id="@+id/tv_card_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/card_margin_half"
            android:textAppearance="@style/StyleTitle14"
            android:textColor="@color/header_text"
            tools:text="Название Категории" />

        <TextView
            android:id="@+id/tv_card_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/card_margin_half"
            android:paddingEnd="@dimen/card_margin_half"
            android:paddingBottom="@dimen/card_margin_half"
            android:textColor="@color/header_text"
            tools:text="Описание категории описывает содержание этой категории" />

    </LinearLayout>

</androidx.cardview.widget.CardView>